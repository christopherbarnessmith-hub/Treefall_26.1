{
	"schemaVersion": 1,
	"id": "treefall",
	"version": "${version}",
	"name": "Treefall",
	"description": "Chop the base of a tree with an axe and the whole thing comes down — logs drop instantly, leaves vanish, and you earn XP for every log felled. Sneak to bypass. Fully configurable.",
	"authors": [
		"KingxIon!"
	],
	"contact": {
		"homepage": "https://ionwiki.netlify.app/",
		"sources": "https://github.com/christopherbarnessmith-hub/Treefall_26.1"
	},
	"license": "CC0-1.0",
	"icon": "assets/treefall/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.kingxion.treefall.Treefall"
		],
		"client": [
			"com.kingxion.treefall.client.TreefallClient"
		]
	},
	"mixins": [
		"treefall.mixins.json",
		{
			"config": "treefall.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}